import * as THREE from 'three';

// 1. Scene Setup
const container = document.getElementById('canvas-container');
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, container.clientWidth / container.clientHeight, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(container.clientWidth, container.clientHeight);
container.appendChild(renderer.domElement);

// 2. Create the Crystal (Icosahedron)
const geometry = new THREE.IcosahedronGeometry(1);
const material = new THREE.MeshStandardMaterial({ color: 0xaaaaaa, wireframe: true });
const crystal = new THREE.Mesh(geometry, material);
scene.add(crystal);

const light = new THREE.PointLight(0xffffff, 1);
light.position.set(5, 5, 5);
scene.add(light, new THREE.AmbientLight(0x404040));
camera.position.z = 3;

// 3. Mathematical Prediction Logic (The Elo Model)
function calculateWinProbability(ratingA, ratingB) {
    // Probability of A winning
    return 1 / (1 + Math.pow(10, (ratingB - ratingA) / 400));
}

// 4. Interaction
document.getElementById('predict-btn').addEventListener('click', () => {
    const ratingV = parseFloat(document.getElementById('visiting-rating').value);
    const ratingH = parseFloat(document.getElementById('home-rating').value);
    
    if (isNaN(ratingV) || isNaN(ratingH)) return;

    const probV = calculateWinProbability(ratingV, ratingH);
    
    // Animate based on results
    // Speed relates to the margin of the prediction
    const confidence = Math.abs(probV - 0.5) * 2;
    crystal.material.color.set(probV > 0.5 ? 0xff4d4d : 0x4d79ff);
    crystal.scale.set(1 + confidence, 1 + confidence, 1 + confidence);
});

// 5. Animation Loop
function animate() {
    requestAnimationFrame(animate);
    crystal.rotation.x += 0.01;
    crystal.rotation.y += 0.01;
    renderer.render(scene, camera);
}
animate();
